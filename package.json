{
  "name": "tierhub",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "convex": "^1.33.1",
      "better-auth": "1.5.3",
      "@convex-dev/better-auth": "^0.11.3",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @tierhub/backend dev",
    "dev:setup": "turbo -F @tierhub/backend dev:setup",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@tierhub/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tierhub/config": "workspace:*",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.3.11"
}
